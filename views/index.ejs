<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Siber Vatan | Blog</title>
    <link rel="icon" type="image/png" href="/favicon.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: #f8f9fa; font-family: 'Inter', sans-serif; }
        .navbar { background: #1a1a1a; border-bottom: 3px solid #0d6efd; padding: 15px 0; }
        .nav-logo { height: 45px; }
        .blog-card { border: none; border-radius: 15px; background: #fff; transition: 0.3s; }
        .blog-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark mb-5 shadow">
        <div class="container">
            <a class="navbar-brand" href="/">
                <img src="/logo.png" alt="Siber Vatan" class="nav-logo">
            </a>
            <a href="/admin" class="btn btn-primary btn-sm px-4">Admin Paneli</a>
        </div>
    </nav>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 text-center mb-5">
                <h1 class="display-6 fw-bold text-dark">Son Haberler</h1>
                <div class="bg-primary mx-auto" style="height: 4px; width: 50px; border-radius: 2px;"></div>
            </div>
            <div class="col-md-8">
                <% if(posts.length > 0) { %>
                    <% posts.forEach(post => { %>
                        <div class="card blog-card shadow-sm p-4 mb-4">
                            <small class="text-primary fw-bold text-uppercase"><%= post.date %></small>
                            <h2 class="h4 mt-2 fw-bold"><%= post.title %></h2>
                            <p class="text-muted" style="white-space: pre-wrap;"><%= post.content %></p>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p class="text-center text-muted">Henüz yazı yayınlanmadı.</p>
                <% } %>
            </div>
        </div>
    </div>
</body>
</html>