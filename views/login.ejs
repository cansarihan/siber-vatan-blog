<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Siber Vatan | Giriş</title>
    <link rel="icon" type="image/png" href="/favicon.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: #0f172a; height: 100vh; display: flex; align-items: center; font-family: 'Inter', sans-serif; }
        .login-card { width: 380px; border-radius: 20px; border: none; overflow: hidden; background: #fff; }
        .login-logo { max-width: 160px; height: auto; margin-bottom: 20px; }
    </style>
</head>
<body>
    <div class="card login-card mx-auto shadow-lg">
        <div class="card-body p-5 text-center">
            <img src="/login-logo.png" alt="Siber Vatan" class="login-logo">
            <p class="text-muted small mb-4">Lütfen yönetici bilgilerinizi girin.</p>
            <% if (error) { %> <div class="alert alert-danger py-2 small"><%= error %></div> <% } %>
            <form action="/login" method="POST">
                <input type="text" name="username" class="form-control mb-3" placeholder="Kullanıcı Adı" required>
                <input type="password" name="password" class="form-control mb-4" placeholder="Şifre" required>
                <button type="submit" class="btn btn-primary w-100 fw-bold py-2 shadow-sm">Giriş Yap</button>
            </form>
            <div class="mt-4"><a href="/" class="text-decoration-none text-muted small">← Siteye Dön</a></div>
        </div>
    </div>
</body>
</html>